# Google Gemini API Key
# Get your free key at: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Trello Integration (for task tracking per account)
# Get keys at: https://trello.com/power-ups/admin
TRELLO_API_KEY=your_trello_api_key_here
TRELLO_TOKEN=your_trello_token_here
TRELLO_TODO_LIST_ID=your_trello_todo_list_id_here
TRELLO_DONE_LIST_ID=your_trello_done_list_id_here